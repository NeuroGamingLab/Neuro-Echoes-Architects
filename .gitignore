# Python
__pycache__/
*.py[cod]
.venv/
venv/
.env
.env.*

# ML artifacts (keep .gitkeep dirs)
models/explorer_agent/*
!models/.gitkeep
!models/explorer_agent/.gitkeep
logs/*
